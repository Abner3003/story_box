# StoryBox
# Copia este arquivo para `.env` e preenche com os valores reais do teu ambiente.

# Servidor
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Postgres do Supabase, de preferência o host do pooler em Connect > Database
DATABASE_URL=postgresql://postgres:your-password@your-pooler-host.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require

# Redis local para BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# Meta / WhatsApp Cloud API
# O backend aceita tanto os nomes antigos `WHATSAPP_*` quanto os novos `META_*`.
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-whatsapp-access-token
META_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
META_VERIFY_TOKEN=your-webhook-verify-token

# AbacatePay
ABACATEPAY_API_KEY=

# URLs públicas usadas por docs e fluxo de onboarding
PUBLIC_API_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3001
APP_URL=http://localhost:3001
STORYBOX_CONSENT_URL=https://storybox.com.br/consent
STORYBOX_INTRO_VIDEO_URL=
