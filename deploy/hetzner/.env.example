# Copie este arquivo para `.env` no diretório de deploy da VM.

PORT=3001
NODE_ENV=production

GHCR_USERNAME=your-ghcr-username
IMAGE_TAG=latest
API_DOMAIN=api.storybox.com

REDIS_HOST=redis
REDIS_PORT=6379

DATABASE_URL=postgresql://...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key

META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-meta-access-token
META_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=your-verify-token
META_VERIFY_TOKEN=your-verify-token

ABACATEPAY_API_KEY=your-abacatepay-api-key
ABACATEPAY_WEBHOOK_SECRET=your-abacatepay-webhook-secret
ADMIN_API_KEY=your-admin-api-key
APP_URL=https://storybox.com.br
API_PUBLIC_URL=https://api.storybox.com
PUBLIC_API_URL=https://api.storybox.com
STORYBOX_CONSENT_URL=https://storybox.com.br/consent
STORYBOX_INTRO_VIDEO_URL=
WHATSAPP_WEEKLY_TEMPLATE_NAME=
